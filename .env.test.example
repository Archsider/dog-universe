# Copier en .env.test (gitignored) puis remplir.
# Le fichier .env.test ne doit JAMAIS être committé.

# URL de base ciblée par les tests E2E (prod par défaut)
PLAYWRIGHT_BASE_URL=https://app.doguniverse.ma

# Compte CLIENT dédié aux tests E2E (créé manuellement, isWalkIn=false)
TEST_CLIENT_EMAIL=
TEST_CLIENT_PASSWORD=
TEST_CLIENT_NAME=

# Compte ADMIN/SUPERADMIN pour les opérations de setup (reset contrat avant test signature)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
