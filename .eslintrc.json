{
  "extends": [
    "next/core-web-vitals",
    "next/typescript"
  ],
  "plugins": ["dog-universe"],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/consistent-type-assertions": ["warn", {
      "assertionStyle": "as",
      "objectLiteralTypeAssertions": "allow-as-parameter"
    }],
    "@typescript-eslint/no-non-null-assertion": "warn",
    "no-restricted-imports": ["error", {
      "paths": [
        {
          "name": "@/lib/sms",
          "importNames": ["sendSMS", "sendAdminSMS"],
          "message": "Direct sendSMS/sendAdminSMS calls bypass the SmsLog dedup and cause duplicate messages to the client. Use `sendSmsNow` from '@/lib/notify-now' instead. See ADR-0007."
        }
      ]
    }],
    "dog-universe/no-getmonth-on-date-casa": "error",
    "dog-universe/no-money-tofixed": "error",
    "dog-universe/no-direct-payment-create": "error",
    "dog-universe/no-prisma-date-without-helper": "error",
    "dog-universe/no-direct-invoice-mutation": "error",
    "dog-universe/no-direct-revenue-computation": "error",
    "dog-universe/no-hardcoded-product-without-id": "error",
    "dog-universe/no-naive-casa-timezone-cast": "error"
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*", "**/*.test.ts", "**/*.test.tsx", "**/*.test.js", "e2e/**/*"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-non-null-assertion": "off",
        "@typescript-eslint/consistent-type-assertions": "off",
        "no-restricted-imports": "off",
        "dog-universe/no-getmonth-on-date-casa": "off",
        "dog-universe/no-money-tofixed": "off",
        "dog-universe/no-direct-payment-create": "off",
        "dog-universe/no-prisma-date-without-helper": "off",
        "dog-universe/no-direct-invoice-mutation": "off",
        "dog-universe/no-direct-revenue-computation": "off",
        "dog-universe/no-hardcoded-product-without-id": "off",
        "dog-universe/no-naive-casa-timezone-cast": "off"
      }
    },
    {
      "files": ["scripts/**/*", "prisma/**/*"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "no-restricted-imports": "off",
        "dog-universe/no-getmonth-on-date-casa": "off",
        "dog-universe/no-money-tofixed": "off",
        "dog-universe/no-direct-payment-create": "off",
        "dog-universe/no-prisma-date-without-helper": "off",
        "dog-universe/no-direct-invoice-mutation": "off",
        "dog-universe/no-direct-revenue-computation": "off",
        "dog-universe/no-hardcoded-product-without-id": "off",
        "dog-universe/no-naive-casa-timezone-cast": "off"
      }
    },
    {
      "files": ["eslint-rules/**/*"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "no-restricted-imports": "off",
        "dog-universe/no-getmonth-on-date-casa": "off",
        "dog-universe/no-money-tofixed": "off",
        "dog-universe/no-direct-payment-create": "off",
        "dog-universe/no-prisma-date-without-helper": "off",
        "dog-universe/no-direct-invoice-mutation": "off",
        "dog-universe/no-direct-revenue-computation": "off",
        "dog-universe/no-hardcoded-product-without-id": "off",
        "dog-universe/no-naive-casa-timezone-cast": "off"
      }
    },
    {
      "files": [
        "src/lib/notify-now.ts",
        "src/lib/sms.ts",
        "src/lib/queues/**/*",
        "src/workers/**/*",
        "src/app/api/cron/heartbeat/route.ts",
        "src/app/api/cron/invariants-check/route.ts",
        "src/app/api/admin/clients/*/sms/route.ts",
        "src/app/api/admin/diagnostics/test-sms/route.ts"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
