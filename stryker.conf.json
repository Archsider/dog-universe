{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/core/schema/stryker-schema.json",
  "_comment": "Stryker mutation testing — cible les modules métier critiques (billing, accounting, loyalty, capacity, category). Run < 5 min visé. Install: npm install -D @stryker-mutator/core @stryker-mutator/vitest-runner",
  "packageManager": "npm",
  "testRunner": "vitest",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/lib/billing.ts",
    "src/lib/accounting.ts",
    "src/lib/loyalty.ts",
    "src/lib/capacity.ts",
    "src/lib/category.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true,
  "disableTypeChecks": "src/**/*.{js,ts,jsx,tsx}"
}
