# ────────────────────────────────────────────────────────────
# Dog Universe — Variables d'environnement (référence Vercel)
# Copier ce fichier, remplir les valeurs, et les ajouter dans
# le dashboard Vercel : Settings > Environment Variables
# ────────────────────────────────────────────────────────────

# Base de données Supabase
# Récupérer depuis : Supabase > Settings > Database > Connection string
DATABASE_URL=             # URL pooler (port 6543) — utilisé en production/serverless
DIRECT_URL=               # URL directe (port 5432) — utilisé pour les migrations Prisma

# Supabase (Storage)
# Récupérer depuis : Supabase > Settings > API
SUPABASE_URL=             # https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY= # Clé service role (secret) — ne jamais exposer côté client
SUPABASE_STORAGE_BUCKET=uploads # Nom du bucket Storage (à créer dans Supabase > Storage)

# Authentification NextAuth
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://doguniverse.ma

# URL publique de l'app (utilisée dans les liens des emails)
NEXT_PUBLIC_APP_URL=https://doguniverse.ma

# Email via Resend SMTP
# Clé API disponible sur : https://resend.com/api-keys
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=    # Clé API Resend (commence par re_...)
EMAIL_FROM=Dog Universe <noreply@doguniverse.ma>

# Cron job (sécurité)
# Générer avec : openssl rand -base64 32
# À ajouter aussi dans Vercel > Settings > Cron Jobs
CRON_SECRET=
