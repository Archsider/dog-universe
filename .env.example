# =============================================================================
# Dog Universe — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# JAMAIS committer .env.local — il est dans .gitignore
# =============================================================================

# --- Base de données (Supabase / PostgreSQL) ----------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- NextAuth -----------------------------------------------------------------
# Générer avec : openssl rand -base64 32
AUTH_SECRET="changeme-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Supabase Storage (obligatoire en production) -----------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="uploads"
SUPABASE_PRIVATE_STORAGE_BUCKET="uploads-private"

# --- Email (nodemailer) -------------------------------------------------------
# Laisser vide en dev → Ethereal automatique (preview dans les logs)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="user@example.com"
EMAIL_SERVER_PASSWORD="your-smtp-password"
EMAIL_FROM='"Dog Universe" <noreply@doguniverse.ma>'

# --- SMS Gateway (optionnel) --------------------------------------------------
# DOIT utiliser HTTPS en production pour protéger les credentials Basic auth
SMS_ENABLED="false"
SMS_GATEWAY_URL="https://your-gateway-url:8080"
SMS_GATEWAY_USER="admin"
SMS_GATEWAY_PASS="your-gateway-password"

# --- Rate limiting (Upstash Redis) — optionnel en dev, requis en prod ---------
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- Application --------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SENTRY_DSN=""

# --- Crons (Vercel) -----------------------------------------------------------
# Générer avec : openssl rand -hex 32
CRON_SECRET="changeme-generate-with-openssl-rand-hex-32"

# --- Bootstrap SuperAdmin (usage unique, supprimer après) --------------------
SUPERADMIN_SECRET="changeme-strong-secret"

# --- Divers -------------------------------------------------------------------
# MAX_FILE_SIZE en octets (défaut: 5242880 = 5MB)
MAX_FILE_SIZE="5242880"
# UPLOAD_DIR uniquement en dev local (filesystem)
UPLOAD_DIR="public/uploads"

# --- Claude / Anthropic (optionnel — fonctionnalités IA) ----------------------
ANTHROPIC_API_KEY="sk-ant-..."
